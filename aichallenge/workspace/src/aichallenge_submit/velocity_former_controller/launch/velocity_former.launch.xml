<launch>

  <arg name="velocity_former_node_param" default="$(find-pkg-share velocity_former_controller)/config/velocity_former_node.param.yaml"/>
  <arg name="use_sim_time" default="true"/>
  <arg name="trajectory_topic" default="/planning/scenario_planning/trajectory"/>
  <arg name="control_cmd_topic" default="/control/command/control_cmd"/>
  <arg name="velocity_onnx_path" default="$(find-pkg-share velocity_former_controller)/ckpt/velocity_former_velocity.onnx"/>
  <arg name="steering_onnx_path" default=""/>

  <node pkg="velocity_former_controller"
        exec="velocity_former_controller_node.py"
        name="velocity_former_controller_node"
        output="screen">

    <param from="$(var velocity_former_node_param)"/>
    <param name="model.velocity_onnx_path" value="$(var velocity_onnx_path)"/>
    <param name="model.steering_onnx_path" value="$(var steering_onnx_path)"/>
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <remap from="/planning/scenario_planning/trajectory" to="$(var trajectory_topic)"/>
    <remap from="/control/command/control_cmd" to="$(var control_cmd_topic)"/>
  </node>

</launch>
