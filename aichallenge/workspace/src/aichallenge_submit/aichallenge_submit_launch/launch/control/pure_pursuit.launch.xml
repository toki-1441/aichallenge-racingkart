<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="simulation" default="true"/>
  <arg name="use_sim_time" default="true"/>
  <arg name="output_control_cmd_topic" default="/control/command/control_cmd"/>
  <arg name="raw_debug_control_cmd_topic" default="/control/command/control_cmd_raw"/>

  <let name="steering_tire_angle_gain_var" value="1.50" if="$(var simulation)"/>
  <let name="steering_tire_angle_gain_var" value="1.639" unless="$(var simulation)"/>

  <node pkg="simple_pure_pursuit" exec="simple_pure_pursuit" name="simple_pure_pursuit_node" output="screen">
    <param name="use_external_target_vel" value="false"/>
    <param name="external_target_vel" value="10.0"/>
    <param name="wheel_base" value="1.087"/>
    <param name="lookahead_gain" value="0.30"/>
    <param name="lookahead_min_distance" value="1.6"/>
    <param name="speed_proportional_gain" value="1.0"/>
    <param name="steering_tire_angle_gain" value="$(var steering_tire_angle_gain_var)"/>
    <param name="steering_tire_angle_offset" value="0.0"/>
    <param name="steering_tire_rotation_rate" value="2.0"/>
    <param name="max_steering_tire_angle" value="0.64"/>
    <param name="use_dynamic_window" value="true"/>
    <param name="use_racing_dynamic_window" value="true"/>
    <param name="max_linear_vel" value="8.3"/>
    <param name="min_linear_vel" value="0.0"/>
    <param name="max_angular_vel" value="6.0"/>
    <param name="min_angular_vel" value="-6.0"/>
    <param name="max_linear_accel" value="5.0"/>
    <param name="max_linear_decel" value="-2.5"/>
    <param name="max_angular_accel" value="20.0"/>
    <param name="max_angular_decel" value="-20.0"/>
    <param name="control_period" value="0.01"/>
    <param name="use_curvature_speed_control" value="true"/>
    <param name="max_lateral_accel" value="3.0"/>
    <param name="braking_decel" value="2.5"/>
    <param name="speed_preview_distance" value="25.0"/>
    <param name="min_curve_velocity" value="1.2"/>
    <param name="tracking_error_velocity" value="2.0"/>
    <param name="lateral_error_brake_threshold" value="1.0"/>
    <param name="yaw_error_brake_threshold" value="0.55"/>

    <remap from="input/kinematics" to="/localization/kinematic_state"/>
    <remap from="input/trajectory" to="/planning/scenario_planning/trajectory"/>
    <remap from="output/control_cmd" to="$(var output_control_cmd_topic)"/>
    <remap from="output/raw_control_cmd" to="$(var raw_debug_control_cmd_topic)"/>
  </node>
</launch>
